---
import Layout from '../layouts/Layout.astro';
import ContactsCard from '../components/ContactsCard.astro';
---

<Layout
	title="Simone Ferretti"
	description="Get in touch with a Full-Stack Developer. TypeScript, Next.js, NestJS, PostgreSQL, GCP. Available for freelance work."
>
	<main class="page-main text-accent flex flex-col">
		<p class="text-[2rem] font-light text-center mb-0 max-[768px]:text-[1.5rem]">
			<span>Let's make <span class="underline font-medium">great things</span></span>
		</p>
		<p class="text-[4rem] font-bold leading-none text-center mt-0 mb-[1em] max-[768px]:text-[3rem]">
			<span class="text-gradient">Together</span>
		</p>
		<section class="max-[768px]:grid">
			<ContactsCard />
		</section>
	</main>
</Layout>
