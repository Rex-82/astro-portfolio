---
import Layout from '../layouts/Layout.astro';
import ContactsCard from '../components/ContactsCard.astro';

const siteOrigin = 'https://simoneferretti.dev';
const pageUrl = `${siteOrigin}/contacts/`;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ContactPage',
	'@id': `${pageUrl}#contactpage`,
	url: pageUrl,
	name: 'Contact Simone Ferretti',
	description: 'Get in touch with Simone Ferretti, Full-Stack Developer. Find me on GitHub, LinkedIn, or by email.',
	mainEntity: {
		'@type': 'Person',
		'@id': `${siteOrigin}/#person`,
	},
};
---

<Layout
	title="Contact | Simone Ferretti"
	description="Get in touch with Simone Ferretti, Full-Stack Developer. Find me on GitHub, LinkedIn, or by email. Open to interesting product and tooling projects."
	jsonLd={jsonLd}
>
	<main class="page-main text-accent flex flex-col items-center">
		<p
			class="text-[2rem] font-light text-center mb-0 max-[768px]:text-[1.5rem]"
		>
			<span>Let's build</span>
		</p>
		<p
			class="text-[4rem] font-bold leading-none text-center mt-0 mb-[0.5em] max-[768px]:text-[3rem]"
		>
			<span class="text-gradient">Something real</span>
		</p>
		<section class="max-[768px]:grid">
			<ContactsCard />
		</section>
	</main>
</Layout>
