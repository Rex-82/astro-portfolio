---
import Layout from '../../layouts/Layout.astro';
import PageTitle from '../../components/PageTitle.astro';
import RssSubscribe from '../../components/RssSubscribe.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { generateCover } from '../../lib/generate-cover';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<Layout
	title="Blog — Simone Ferretti"
	description="Thoughts on web development, tools, and side projects by Simone Ferretti."
>
	<main>
		<div class="relative">
			<PageTitle title="Blog" />
			<div class="absolute top-0 right-0">
				<RssSubscribe />
			</div>
		</div>
		<p class="blog-intro">
			Thoughts on web development, tools, and side projects.
		</p>
		{posts.length === 0 ? (
			<p class="empty">No posts yet. Check back soon.</p>
		) : (
			<ul class="post-list">
				{posts.map((post, index) => (
					<li
						class="post-card"
						style={`animation-delay: ${index * 0.1}s`}
					>
						<a href={`/blog/${post.id}/`}>
							<div class="post-cover-wrapper">
									{post.data.coverImage ? (
										<Image
											src={post.data.coverImage}
											alt={`Cover image for ${post.data.title}`}
											class="post-cover"
											widths={[400, 800]}
											sizes="(max-width: 800px) 100vw, 800px"
										/>
									) : (
										<div class="post-cover-generated" set:html={generateCover(post.id)} />
									)}
								</div>
							<div class="post-body">
								<h2>{post.data.title}</h2>
								<p class="description">{post.data.description}</p>
								<div class="post-meta">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</time>
									{post.data.tags.length > 0 && (
										<div class="tags">
											{post.data.tags.map((tag) => (
												<span class="tag">{tag}</span>
											))}
										</div>
									)}
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		)}
	</main>
</Layout>

<style>
	main {
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: var(--color-text-primary);
		line-height: 1.6;
	}

	.blog-intro {
		color: var(--color-text-secondary);
		text-align: center;
		margin-top: -1rem;
		margin-bottom: 2.5rem;
		font-size: 0.9375rem;
	}

	.empty {
		text-align: center;
		color: var(--color-text-secondary);
	}

	.post-list {
		list-style: none;
		padding: 0;
		display: grid;
		gap: 2rem;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.post-card {
		border-radius: 8px;
		box-shadow: inset 0 0 0 1px var(--color-border-mid);
		transition:
			background-position 0.6s var(--ease-out-expo),
			box-shadow 0.6s var(--ease-out-expo),
			transform 0.6s var(--ease-out-expo);
		background-size: 400%;
		background-position: 100%;
		animation: fadeInUp 0.5s var(--ease-out-expo) both;
	}

	.post-card a {
		display: flex;
		text-decoration: none;
		color: inherit;
		border-radius: 8px;
		background: var(--color-bg);
		overflow: hidden;
	}

	.post-cover-wrapper {
		flex-shrink: 0;
		width: 240px;
		overflow: hidden;
	}

	.post-cover {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.6s var(--ease-out-expo);
	}

	.post-cover-generated {
		height: 100%;
		overflow: hidden;
		transition: transform 0.6s var(--ease-out-expo);
	}

	.post-cover-generated :global(svg) {
		width: 100%;
		height: 100%;
		display: block;
	}

	.post-body {
		flex: 1;
		min-width: 0;
		padding: 1.25rem 1.5rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.post-card h2 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
		color: var(--color-text-primary);
		transition:
			color 0.6s var(--ease-out-expo),
			transform 0.3s var(--ease-out-expo);
	}

	.description {
		margin: 0 0 0.75rem;
		color: var(--color-text-secondary);
	}

	@media screen and (max-width: 600px) {
		.post-card a {
			flex-direction: column;
		}

		.post-cover-wrapper {
			width: 100%;
			height: 180px;
		}
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}

	time {
		font-size: 0.75rem;
		color: var(--color-text-secondary);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.tag {
		box-shadow: inset 0 0 0 1px var(--color-border-subtle);
		background: var(--color-surface-tag);
		padding: 0.25rem 0.625rem;
		border-radius: 5rem;
		font-size: 0.75rem;
		color: var(--color-accent);
		transition: color 0.6s var(--ease-out-expo);
	}

	@media screen and (min-width: 768px) {
		.post-card:hover {
			background-position: 0;
			background-image: var(--color-accent-gradient);
			transform: scale(1.02);
		}

		.post-card:hover .post-cover,
		.post-card:hover .post-cover-generated {
			transform: scale(1.05);
		}

		.post-card:hover h2 {
			color: var(--color-accent-light);
			transform: translateX(4px);
		}

		.post-card:hover .description,
		.post-card:hover time,
		.post-card:hover .tag {
			color: var(--color-accent-light-dimmed);
		}

		.post-card:hover .tag {
			background-color: color-mix(in srgb, var(--color-accent-light-dimmed) 20%, transparent);
		}
	}
</style>
