---
import Layout from '../../layouts/Layout.astro';
import PageTitle from '../../components/PageTitle.astro';
import RssSubscribe from '../../components/RssSubscribe.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
	title="Blog — Simone Ferretti"
	description="Thoughts on web development, tools, and side projects by Simone Ferretti."
>
	<main class="page-main text-text-primary leading-[1.6]">
		<div class="relative">
			<PageTitle title="Blog" />
			<div class="absolute top-0 right-0">
				<RssSubscribe />
			</div>
		</div>
		<p class="text-[var(--color-text-secondary)] text-center -mt-4 mb-10 text-[0.9375rem]">
			Thoughts on web development, tools, and side projects.
		</p>
		{posts.length === 0 ? (
			<p class="text-center text-[var(--color-text-secondary)]">No posts yet. Check back soon.</p>
		) : (
			<ul class="list-none p-0 grid gap-8">
				{posts.map((post, index) => (
					<PostCard
						id={post.id}
						title={post.data.title}
						description={post.data.description}
						pubDate={post.data.pubDate}
						tags={post.data.tags}
						coverImage={post.data.coverImage}
						animationDelay={index * 0.1}
					/>
				))}
			</ul>
		)}
	</main>
</Layout>
