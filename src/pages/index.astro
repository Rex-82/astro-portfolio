---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import Card from '../components/Card.astro';
import PostCard from '../components/PostCard.astro';
import { CURRENT_STATUS } from 'astro:env/server';
import { getFeaturedProjects } from '../lib/github';
import { getCollection } from 'astro:content';

const workWith = ['TypeScript', 'Next.js', 'NestJS', 'PostgreSQL'];
const learning = ['Rust', 'Go'];
const like = ['Linux', 'Docker', 'Neovim', 'Lists'];

const allPosts = await getCollection('blog');
const latestPost = allPosts
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

// Featured project slug — must match GitHub repo `name` exactly.
const [featuredProject] = await getFeaturedProjects(['nvim-config']);
---

<Layout
	title="Simone Ferretti — Full-Stack Developer"
	description="Full-Stack Developer building products end to end. TypeScript, Next.js, NestJS, PostgreSQL."
>
	<main class="p-4 w-[800px] max-w-[calc(100%-2rem)] text-[16px] text-accent leading-[1.6] flex flex-col items-center">
		<header class="flex flex-col items-center w-fit tracking-[0.125em]">
			<PageTitle title="Simone Ferretti" />
			<p class="text-[1.5rem] uppercase tracking-[0.125em] self-end -mt-[2.5em] m-0 max-[768px]:text-[1.125rem] max-[400px]:text-[1rem]">
				<span>full-stack developer</span>
			</p>
		</header>

		<div
			class="grid grid-cols-3 grid-rows-[auto_2fr]
			       [grid-template-areas:'status_status_status'_'sec2_sec3_sec4']
			       justify-items-center rounded-[7px] w-full mt-2
			       max-[768px]:grid-cols-1 max-[768px]:grid-rows-[auto_repeat(3,auto)]
			       max-[768px]:[grid-template-areas:'status'_'sec2'_'sec3'_'sec4']
			       max-[768px]:gap-y-[1em] max-[768px]:mb-8"
		>
			{CURRENT_STATUS && (
				<p
					class="[grid-area:status] text-center text-[0.75rem] uppercase tracking-[0.1em]
					       [color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       mb-2 mx-0 p-0"
				>
					{CURRENT_STATUS}
				</p>
			)}

			<section
				class="[grid-area:sec2] flex flex-col p-4
				       max-[768px]:pt-0 max-[768px]:border-b max-[768px]:border-border max-[768px]:items-center"
			>
				<h2
					class="text-[0.875rem] uppercase tracking-[0.125em] m-0 p-0
					       [color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       max-[768px]:text-[1rem]"
				>
					What I work with
				</h2>
				<ul
					class="list-none m-0 p-0 ml-2 pl-2 border-l
					       [border-color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       max-[768px]:flex max-[768px]:items-center max-[768px]:gap-x-[1em]
					       max-[768px]:h-8 max-[768px]:border-l-0 max-[768px]:m-0 max-[768px]:p-0"
				>
					{workWith.map((e) => <li>{e}</li>)}
				</ul>
			</section>

			<section
				class="[grid-area:sec3] flex flex-col p-4
				       max-[768px]:pt-0 max-[768px]:border-b max-[768px]:border-border max-[768px]:items-center"
			>
				<h2
					class="text-[0.875rem] uppercase tracking-[0.125em] m-0 p-0
					       [color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       max-[768px]:text-[1rem]"
				>
					What I am learning
				</h2>
				<ul
					class="list-none m-0 p-0 ml-2 pl-2 border-l
					       [border-color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       max-[768px]:flex max-[768px]:items-center max-[768px]:gap-x-[1em]
					       max-[768px]:h-8 max-[768px]:border-l-0 max-[768px]:m-0 max-[768px]:p-0"
				>
					{learning.map((e) => <li>{e}</li>)}
				</ul>
			</section>

			<section
				class="[grid-area:sec4] flex flex-col p-4
				       max-[768px]:pt-0 max-[768px]:border-b max-[768px]:border-border max-[768px]:items-center"
			>
				<h2
					class="text-[0.875rem] uppercase tracking-[0.125em] m-0 p-0
					       [color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       max-[768px]:text-[1rem]"
				>
					More things I like
				</h2>
				<ul
					class="list-none m-0 p-0 ml-2 pl-2 border-l
					       [border-color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]
					       max-[768px]:flex max-[768px]:items-center max-[768px]:gap-x-[1em]
					       max-[768px]:h-8 max-[768px]:border-l-0 max-[768px]:m-0 max-[768px]:p-0"
				>
					{like.map((e) => <li>{e}</li>)}
				</ul>
			</section>
		</div>

		<section class="w-full mt-8 flex flex-col gap-10">
			{latestPost && (
				<div class="flex flex-col gap-3">
					<h2
						class="text-[0.875rem] uppercase tracking-[0.125em] m-0 p-0
						       [color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]"
					>
						Latest post
					</h2>
					<ul class="list-none p-0 m-0">
						<PostCard
							id={latestPost.id}
							title={latestPost.data.title}
							description={latestPost.data.description}
							pubDate={latestPost.data.pubDate}
							tags={latestPost.data.tags}
							coverImage={latestPost.data.coverImage}
						/>
					</ul>
					<a
						href="/blog/"
						class="text-[0.75rem] uppercase tracking-[0.1em] text-[var(--color-text-secondary)]
						       no-underline self-start transition-colors duration-300 ease-[var(--ease-out-expo)]
						       hover:text-[var(--color-accent-light)]"
					>
						Read more on the Blog →
					</a>
				</div>
			)}

			{featuredProject && (
				<div class="flex flex-col gap-3">
					<h2
						class="text-[0.875rem] uppercase tracking-[0.125em] m-0 p-0
						       [color:color-mix(in_srgb,var(--color-accent-light)_70%,transparent)]"
					>
						Featured project
					</h2>
					<ul class="list-none p-0 m-0">
						<Card
							title={featuredProject.name}
							body={featuredProject.description ?? ''}
							homepage={featuredProject.homepage}
							href={featuredProject.html_url}
							topics={featuredProject.topics}
						/>
					</ul>
					<a
						href="/projects/"
						class="text-[0.75rem] uppercase tracking-[0.1em] text-[var(--color-text-secondary)]
						       no-underline self-start transition-colors duration-300 ease-[var(--ease-out-expo)]
						       hover:text-[var(--color-accent-light)]"
					>
						All projects →
					</a>
				</div>
			)}
		</section>
	</main>
</Layout>
