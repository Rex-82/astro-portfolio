---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import CtaButton from '../components/CtaButton.astro';
import PageTitle from '../components/PageTitle.astro';
import { getProjects } from '../lib/github';

const projects = await getProjects();

const siteOrigin = 'https://simoneferretti.dev';

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	'@id': `${siteOrigin}/projects/#itemlist`,
	url: `${siteOrigin}/projects/`,
	name: "Simone Ferretti's Projects",
	description: 'Open source projects and experiments by Simone Ferretti.',
	itemListElement: projects.map((repo, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		item: {
			'@type': 'SoftwareSourceCode',
			name: repo.name,
			description: repo.description ?? undefined,
			codeRepository: repo.html_url,
			...(repo.language && { programmingLanguage: repo.language }),
			...(repo.topics.length > 0 && { keywords: repo.topics.join(', ') }),
		},
	})),
};
---

<Layout
	title="Projects | Simone Ferretti"
	description="Projects by a Full-Stack Developer. TypeScript, Next.js, NestJS, Go, Rust. Open source tools and experiments."
	jsonLd={jsonLd}
>
	<main class="page-main text-text-primary">
		<PageTitle title="Projects" />
		<ul role="list" class="grid grid-cols-[repeat(auto-fit,minmax(min(35ch,100%),1fr))] gap-8 p-0 list-none max-md:gap-y-4">
			{projects.length === 0 ? (
				<li class="text-text-secondary text-center col-span-full py-8">
					No projects to display right now.
				</li>
			) : (
				projects.map((repo) => (
					<Card
						title={repo.name}
						body={repo.description}
						homepage={repo.homepage}
						href={repo.html_url}
						topics={repo.topics}
	
					/>
				))
			)}
		</ul>
		<CtaButton label="Contact" destination="/contacts/" />
	</main>
</Layout>
