---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import CtaButton from '../components/CtaButton.astro';
import type { Repository } from '../interfaces/github';
import PageTitle from '../components/PageTitle.astro';

const response = await fetch('https://api.github.com/users/Rex-82/repos');
const data = await response.json();
---

<Layout
	title="Simone Ferretti"
	description="Projects by a Full-Stack Developer. TypeScript, Next.js, NestJS, Go, Rust. Open source tools and experiments."
>
	<main>
		<PageTitle title="Projects" />
		<ul role="list" class="link-card-grid">
			{
				data
					?.filter(
						(repo: Repository) =>
							!repo.fork && repo.description !== null && repo.topics.length > 0,
					)
					.sort((a: Repository, b: Repository) =>
						b.updated_at.localeCompare(a.updated_at),
					)
					.map((repo: Repository) => (
						<Card
							title={repo.name}
							body={repo.description}
							homepage={repo.homepage}
							href={repo.html_url}
							topics={repo.topics}
						/>
					))
			}
		</ul>
		<CtaButton label="Contact" destination="/contacts/" />
	</main>
</Layout>

<style>
	main {
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: var(--color-text-primary);
		line-height: 1.6;
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(35ch, 1fr));
		gap: 2rem;
		padding: 0;
	}

	@media screen and (max-width: 768px) {
		.link-card-grid {
			row-gap: 1rem;
		}
	}
</style>
