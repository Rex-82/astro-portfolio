---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import CtaButton from '../components/CtaButton.astro';
import PageTitle from '../components/PageTitle.astro';
import { getProjects } from '../lib/github';
import { getCollection } from 'astro:content';

const projects = await getProjects();

const caseStudyEntries = await getCollection('caseStudies', (e) => !e.data.draft);
const caseStudyMap = new Map(caseStudyEntries.map((e) => [e.data.project, e.id]));
---

<Layout
	title="Projects — Simone Ferretti"
	description="Projects by a Full-Stack Developer. TypeScript, Next.js, NestJS, Go, Rust. Open source tools and experiments."
>
	<main class="page-main text-text-primary">
		<PageTitle title="Projects" />
		<ul role="list" class="grid grid-cols-[repeat(auto-fit,minmax(35ch,1fr))] gap-8 p-0 list-none max-md:gap-y-4">
			{projects.length === 0 ? (
				<li class="text-text-secondary text-center col-span-full py-8">
					No projects to display right now.
				</li>
			) : (
				projects.map((repo) => (
					<Card
						title={repo.name}
						body={repo.description}
						homepage={repo.homepage}
						href={repo.html_url}
						topics={repo.topics}
						caseStudyHref={caseStudyMap.has(repo.name) ? `/case-studies/${caseStudyMap.get(repo.name)}/` : undefined}
					/>
				))
			)}
		</ul>
		<CtaButton label="Contact" destination="/contacts/" />
	</main>
</Layout>
