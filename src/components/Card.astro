---
import GlobeIcon from '../components/icons/GlobeIcon.astro';

interface Props {
	title: string;
	body: string;
	href: string;
	homepage: string;
	topics: Array<string>;

}

const { href, title, body, homepage, topics } = Astro.props;
---

<li class="link-card flex-col">
	<a
		href={href}
		target="_blank"
		rel="noopener"

	>
		<h2>
			{title}
		</h2>
		<p>
			{body.split('. ')[0]}
		</p>
		<div class="topics-list">
			{
				topics?.map((topic: string) => (
					<div class="pill flex items-center justify-center">
						<span>{topic}</span>
					</div>
				))
			}
		</div>
	</a>
	{homepage ?
	<div id="homepage-container">
		<a role="button" aria-labelledby="homepage-label" class="flex items-center justify-center" href={homepage} target="_blank" rel="noopener">
			<span id="homepage-label">Live Demo</span>
			<div id="homepage-link" class="pill flex items-center justify-center">
				<GlobeIcon/>
			</div>
		</a>
	</div>
	: <></>}

</li>
<style>
	.link-card {
		list-style: none;
		display: flex;
		padding: 1px;
		background-image: none;
		background-size: 400%;
		border-radius: 8px;
		background-position: 100%;
		box-shadow: inset 0 0 0 1px var(--color-border);
		cursor: pointer;
		position: relative;
		transform: scale(1);
		transition: background-position 0.6s var(--ease-out-expo),
			background-size 1s var(--ease-out-expo),
			transform 0.6s var(--ease-out-expo);
	}

	.link-card > a {
		width: 100%;
		line-height: 1.4;
		padding: calc(1.5rem - 1px);
		border-radius: 8px;
		color: var(--color-text-primary);
		background: var(--color-bg);
	}

	a {
		text-decoration: none;
	}

	h2 {
		margin: 0;
		font-size: 1.25rem;
		transition: color 0.6s var(--ease-out-expo);
		text-decoration: underline;
		text-decoration-thickness: 1px;
	}

	p {
		margin-top: 0.5rem;
		margin-bottom: 0;
		color: var(--color-text-secondary);
	}

	.topics-list {
		display: flex;
		flex-wrap: wrap;
		margin-top: 1rem;
		row-gap: 0.5rem;
	}

	.pill {
		box-shadow: inset 0 0 0 1px var(--color-border);
		padding: 0.375rem 0.75rem;
		margin: 0 0.125rem;
		border-radius: 5rem;
	}

	.pill > span, #homepage-link, #homepage-label {
		margin: 0;
		padding: 0;
		color: var(--color-accent);
		font-size: 0.875rem;
		transition: color 0.6s var(--ease-out-expo);
	}

	#homepage-container {
		display: flex;
		position: absolute;
		right: 10px;
		top: 10px;
		padding: 0 0 0 0.875rem;
		margin: 0;
	}

	#homepage-label {
		opacity: 0;
		position: relative;
		right: -20%;
		z-index: 0;
		padding-right: 15px;
		padding-left: 10px;
		color: var(--color-accent);
		border: 1px solid var(--color-border);
		border-top-left-radius: 8px;
		border-bottom-left-radius: 8px;
		transition:
			opacity 0.3s var(--ease-out-expo),
			color 0.3s var(--ease-out-expo),
			border-color 0.3s var(--ease-out-expo),
			right 0.6s var(--ease-out-expo);
	}

	#homepage-link {
		position: relative;
		z-index: 1;
		padding: 0;
		margin: 0;
		transform: scale(1);
		width: 44px;
		height: 44px;
		background-color: var(--color-bg);
		transition: background-color 0.6s var(--ease-out-expo),
			transform 0.6s var(--ease-out-expo);
	}

	.pill > a {
		padding: 0.5rem;
	}

	@media screen and (min-width: 768px) {
		.link-card:hover {
			background-position: 0;
			background-image: var(--color-accent-gradient);
			transform: scale(1.02);
		}

		.link-card:hover h2 {
			color: var(--color-accent-light);
		}

		.link-card:hover p,
		.link-card:hover #homepage-link:not(:hover) svg,
		.link-card:hover span {
			color: var(--color-accent-light-dimmed);
		}

		.link-card:hover .pill:not(.homepage-link),
		.link-card:hover .homepage-link:not(:hover) {
			background-color: color-mix(in srgb, var(--color-accent-light-dimmed) 20%, transparent);
		}

		.link-card:hover #homepage-label {
			opacity: 100%;
			right: -12px;
		}

		#homepage-label:hover ~ #homepage-link, #homepage-link:hover {
			background-color: var(--color-text-primary);
		}

		#homepage-link:hover {
			transform: scale(1.1);
		}

		#homepage-label:hover, #homepage-label:has(~ #homepage-link:hover) {
			color: var(--color-text-primary);
			border-color: var(--color-text-primary);
		}

		.link-card:has(#homepage-container:hover) {
			background-size: 200%;
		}
	}

	@media screen and (max-width: 768px) {

		#homepage-label {
			opacity: 100%;
			right: -12px;
		}

	}


</style>
