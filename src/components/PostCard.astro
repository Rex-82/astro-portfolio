---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { generateCover } from '../lib/generate-cover';

interface Props {
	id: string;
	title: string;
	description: string;
	pubDate: Date;
	tags: string[];
	coverImage?: ImageMetadata;
	animationDelay?: number;
}

const { id, title, description, pubDate, tags, coverImage, animationDelay = 0 } = Astro.props;
---

<li
	class="list-none rounded-lg shadow-[inset_0_0_0_1px_var(--color-border-mid)]
	       transition-[background-position,box-shadow,transform] duration-[600ms] ease-[var(--ease-out-expo)]
	       bg-[length:400%] bg-[position:100%]
	       animate-fade-in-up
	       group
	       md:hover:bg-[position:0%] md:hover:bg-[image:var(--color-accent-gradient)] md:hover:scale-[1.02]"
	style={`animation-delay: ${animationDelay}s`}
>
	<a
		href={`/blog/${id}/`}
		class="flex max-[600px]:flex-col no-underline [color:inherit] rounded-lg bg-[var(--color-bg)] overflow-hidden"
	>
		<div class="shrink-0 w-[240px] overflow-hidden max-[600px]:w-full max-[600px]:h-[180px]">
			{coverImage ? (
				<Image
					src={coverImage}
					alt={`Cover image for ${title}`}
					class="w-full h-full object-cover block transition-transform duration-[600ms] ease-[var(--ease-out-expo)] md:group-hover:scale-105"
					widths={[400, 800]}
					sizes="(max-width: 800px) 100vw, 800px"
				/>
			) : (
				<div
					class="post-cover-generated h-full overflow-hidden transition-transform duration-[600ms] ease-[var(--ease-out-expo)] md:group-hover:scale-105"
					set:html={generateCover(id)}
				/>
			)}
		</div>
		<div class="flex-1 min-w-0 py-5 px-6 flex flex-col justify-center">
			<h2
				class="m-0 mb-2 text-[1.25rem] text-text-primary
				       transition-[color,transform] duration-[600ms] ease-[var(--ease-out-expo)]
				       md:group-hover:text-[var(--color-accent-light)] md:group-hover:translate-x-1"
			>
				{title}
			</h2>
			<p class="m-0 mb-3 text-[var(--color-text-secondary)] md:group-hover:text-[var(--color-accent-light-dimmed)]">
				{description}
			</p>
			<div class="flex flex-wrap items-center gap-3">
				<time
					datetime={pubDate.toISOString()}
					class="text-[0.75rem] text-[var(--color-text-secondary)] uppercase tracking-[0.1em] md:group-hover:text-[var(--color-accent-light-dimmed)]"
				>
					{pubDate.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>
				{tags.length > 0 && (
					<div class="flex flex-wrap gap-1.5">
						{tags.map((tag) => (
							<span
								class="shadow-[inset_0_0_0_1px_var(--color-border-subtle)] bg-[var(--color-surface-tag)]
								       px-[0.625rem] py-1 rounded-full text-[0.75rem] text-[var(--color-accent)]
								       transition-[color,background-color] duration-[600ms] ease-[var(--ease-out-expo)]
								       md:group-hover:text-[var(--color-accent-light-dimmed)]
								       md:group-hover:bg-[color-mix(in_srgb,var(--color-accent-light-dimmed)_20%,transparent)]"
							>
								{tag}
							</span>
						))}
					</div>
				)}
			</div>
		</div>
	</a>
</li>
