---
import { ArrowRight, ArrowUpRight } from 'lucide-react';

type Variant = 'bio' | 'link' | 'text' | 'tags';

interface Props {
	variant: Variant;
	index?: string;
	title?: string;
	heading?: string;
	body?: string;
	href?: string;
	// eslint-disable-next-line @typescript-eslint/no-explicit-any
	icon?: any;
	items?: string[];
	featured?: boolean;
	external?: boolean;
	spanClass?: string;
	bgSvg?: string;
	iconOnly?: boolean;
}

const {
	variant,
	index,
	title,
	heading,
	body,
	href,
	icon: Icon,
	items,
	featured = false,
	external = false,
	spanClass = '',
	bgSvg,
	iconOnly = false,
} = Astro.props;

const linkAttrs = external
	? { target: '_blank', rel: 'noopener noreferrer' }
	: {};

const outerFrame =
	'list-none rounded-lg shadow-[inset_0_0_0_1px_var(--color-border-mid)] bg-[length:400%] bg-[position:100%] transition-[background-position,box-shadow,transform] duration-[600ms] ease-[var(--ease-out-expo)]';
const outerHover =
	'group md:hover:bg-[position:0%] md:hover:bg-[image:var(--color-accent-gradient)] md:hover:scale-[1.02]';

const innerBase =
	'flex h-full flex-col gap-4 rounded-lg border border-[var(--color-border-mid)] bg-[var(--color-bg)] transition-colors duration-[600ms] ease-[var(--ease-out-expo)]';
const innerPadding = 'p-5 md:p-6';
const innerPaddingCompact = 'p-3 md:p-6';
const innerHover =
	'md:group-hover:border-[var(--color-accent-light)]';

const metaLabel =
	'flex items-center gap-2 text-[0.65rem] uppercase tracking-[0.08em] text-[var(--color-text-secondary)] md:text-[0.72rem] md:tracking-[0.14em]';
---

{
	variant === 'bio' && (
		<div class={`${outerFrame} ${spanClass}`}>
			<div class={`${innerBase} relative min-h-[220px] gap-4 overflow-hidden p-6 md:min-h-[280px] md:gap-5 md:p-8`}>
				{bgSvg && (
					<div
						class="hub-bio-bg pointer-events-none absolute inset-0"
						aria-hidden="true"
						set:html={bgSvg}
					/>
				)}
				{bgSvg && (
					<div
						class="pointer-events-none absolute inset-0"
						aria-hidden="true"
						style="background: linear-gradient(95deg, color-mix(in srgb, var(--color-bg) 88%, transparent) 0%, color-mix(in srgb, var(--color-bg) 72%, transparent) 50%, color-mix(in srgb, var(--color-bg) 45%, transparent) 100%);"
					/>
				)}
				<span class={`${metaLabel} relative`}>
					<span class="text-[var(--color-border)]">{index ?? '00'}</span>
					<span>intro</span>
				</span>
				{heading && (
					<h1 class="relative m-0 font-bold leading-none text-[2.25rem] max-[480px]:text-[1.75rem] md:text-[3.5rem]">
						<span class="text-gradient">{heading}</span>
					</h1>
				)}
				<p class="relative m-0 mt-auto text-[1.25rem] leading-[1.3] text-[var(--color-accent-light)] max-[480px]:text-[1.0625rem] md:max-w-[28ch] md:text-[1.5rem]">
					{body}
				</p>
			</div>
		</div>
	)
}

{
	variant === 'link' && href && (
		<div class={`${outerFrame} ${outerHover} ${spanClass}`}>
			<a
				href={href}
				{...linkAttrs}
				class={`${innerBase} ${innerHover} ${innerPaddingCompact} no-underline [color:inherit] ${featured ? 'md:p-7' : ''}`}
			>
				<div class="flex items-center justify-between">
					<span class={metaLabel}>
						<span class="text-[var(--color-border)]">{index ?? '00'}</span>
						<span class={iconOnly ? 'max-md:hidden' : ''}>{title}</span>
					</span>
					<span
						aria-hidden="true"
						class={`inline-flex h-[14px] w-[14px] items-center justify-center text-[var(--color-text-secondary)] transition-[transform,color] duration-[600ms] ease-[var(--ease-out-expo)] md:group-hover:translate-x-0.5 md:group-hover:-translate-y-0.5 md:group-hover:text-[var(--color-accent-light)] ${iconOnly ? 'max-md:hidden' : ''}`}
					>
						{external ? (
							<ArrowUpRight size={14} strokeWidth={2} aria-hidden="true" />
						) : (
							<ArrowRight size={14} strokeWidth={2} aria-hidden="true" />
						)}
					</span>
				</div>
				<div class={`mt-auto flex items-end justify-between gap-3 ${iconOnly ? 'max-md:mt-0 max-md:flex-1 max-md:items-center max-md:justify-center' : ''}`}>
					<h3
						class={`m-0 min-w-0 truncate leading-[1.1] text-[var(--color-text-primary)] transition-colors duration-[600ms] ease-[var(--ease-out-expo)] md:group-hover:text-[var(--color-accent-light)] ${iconOnly ? 'max-md:hidden' : ''} ${featured ? 'text-[1.75rem] md:text-[2rem]' : 'text-[1.25rem] md:text-[1.375rem]'}`}
					>
						{body}
					</h3>
					{Icon && (
						<span
							class={`flex shrink-0 items-center justify-center text-[var(--color-text-secondary)] transition-colors duration-[600ms] ease-[var(--ease-out-expo)] md:group-hover:text-[var(--color-accent-light)] ${iconOnly ? 'max-md:h-8 max-md:w-8' : ''} ${featured ? 'h-8 w-8' : 'h-6 w-6'}`}
						>
							<Icon />
						</span>
					)}
				</div>
			</a>
		</div>
	)
}

{
	variant === 'text' && (
		<div class={`${outerFrame} ${spanClass}`}>
			<div class={`${innerBase} ${innerPadding}`}>
				<span class={metaLabel}>
					<span class="text-[var(--color-border)]">{index ?? '00'}</span>
					<span>{title}</span>
				</span>
				<ul class="hub-text-list m-0 flex list-none flex-col gap-2 p-0">
					{items?.map((item) => (
						<li
							class="text-[0.9375rem] leading-[1.5] text-[var(--color-text-secondary)] md:text-[1rem]"
							set:html={item}
						/>
					))}
				</ul>
			</div>
		</div>
	)
}

{
	variant === 'tags' && (
		<div class={`${outerFrame} ${spanClass}`}>
			<div class={`${innerBase} ${innerPadding}`}>
				<span class={metaLabel}>
					<span class="text-[var(--color-border)]">{index ?? '00'}</span>
					<span>{title}</span>
				</span>
				<ul class="m-0 flex list-none flex-wrap gap-2 p-0">
					{items?.map((item) => (
						<li>
							<span class="tag-pill">{item}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	)
}

<style>
	.hub-bio-bg :global(svg) {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		opacity: 0.85;
	}

	.hub-text-list :global(strong) {
		color: var(--color-text-primary);
		font-weight: 500;
	}
</style>
